{
  "name": "oncology-patient-data-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "vercel-build": "vite build",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:analytics": "node --import tsx scripts/test-analytics.ts",
    "test:patient-export": "node --import tsx scripts/test-patient-export.ts",
    "test:csp": "vite build && node --import tsx scripts/test-csp-bundle.ts",
    "test:document-fill": "node --import tsx scripts/test-document-fill.ts",
    "test:gemini-fallback": "node --import tsx scripts/test-gemini-model-fallback.ts",
    "test:ai-fill-review": "node --import tsx scripts/test-ai-fill-review.ts",
    "test:theme": "node --import tsx scripts/test-theme.ts",
    "test:vercel-routing": "node --import tsx scripts/test-vercel-routing.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@opencode-ai/plugin": "1.16.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.14.0",
    "firebase-admin": "13.10.0",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-grid-layout": "^2.2.3",
    "serverless-http": "^4.0.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.12",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  }
}
